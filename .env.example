# ─────────────────────────────────────────────────────────────
# Cappo_Meridian environment configuration
# Copy to `.env.local` and fill in. All connector creds are optional —
# the dashboard shows which integrations are configured.
# ─────────────────────────────────────────────────────────────

# App
# Local dev: http://localhost:3000 · Production: https://cappo.apex-meridian-group.com
APP_BASE_URL=http://localhost:3000
GOOGLE_WORKSPACE_DOMAIN=apex-meridian-group.com
# Comma-separated personal Gmail addresses always allowed to sign in (partner bypass)
PARTNER_EMAILS=
# The two founders' login emails — always allowed to sign in, and mapped to a
# founder identity for the personalized Overview (any email domain is fine).
FOUNDER_55_EMAIL=
FOUNDER_88_EMAIL=

# ── Auth (Auth.js) ───────────────────────────────────────────
# Session signing secret. Generate with: openssl rand -base64 32
# App login uses the same Google OAuth client below (no separate creds).
# Login is gated to the GOOGLE_WORKSPACE_DOMAIN above.
AUTH_SECRET=

# ── Anthropic (AI / Claude research) ─────────────────────────
# Shared AMG Claude account API key (https://console.anthropic.com).
# Powers the AI module; server-side only, never exposed to the browser.
# NOTE: inside a Claude Code session, ANTHROPIC_API_KEY is reserved and won't
# be injected — set CLAUDE_API_KEY there to validate Claude in dev. Production
# uses ANTHROPIC_API_KEY normally.
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=

# ── OpenAI (optional AI provider) ────────────────────────────
# Enables the "GPT (OpenAI)" option in the AI page model switcher.
# Optional model override (default gpt-4o).
OPENAI_API_KEY=
OPENAI_MODEL=

# ── Perplexity (optional AI provider) ────────────────────────
# Enables the "Perplexity" option with its own model sub-selector (Sonar family).
# OpenAI-compatible API. Optional default-model override (default sonar-pro).
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=

# ── Postgres (persistence) ───────────────────────────────────
# Production runs Postgres as a Docker service (see docker-compose.yml); these
# feed both the `db` container and the app's DATABASE_URL. Leave blank for local
# dev to run without persistence (AI chat stays in-session).
POSTGRES_USER=cappo
POSTGRES_PASSWORD=
POSTGRES_DB=cappo
DATABASE_URL=

# Encrypts secrets at rest in Postgres (Google OAuth tokens), AES-256-GCM.
# Any passphrase works. Generate with: openssl rand -base64 32
# Required in production; if unset, tokens are stored unencrypted (dev only).
SECRET_ENCRYPTION_KEY=

# ── Machine-to-machine (M2M) ──────────────────────────────────
# Shared secret ALLIE (allen.i.verse) uses to call Cappo's own /api/agent* server-to-
# server, separate from the human Google login. (Was previously undocumented here
# despite being required by src/lib/env.ts and every /api/agent* route.)
AGENT_API_KEY=

# hvnhavenry-com's Vale agent -- Cappo pulls her cached HVN<->AMG activity report
# directly (agent.ts's vale_get_report tool) for HVN<->AMG business coordination.
# This is Vale's own AGENT_API_KEY on the hvnhavenry-com side, not Cappo's.
VALE_REPORT_URL=
VALE_AGENT_KEY=

# ── GrantOps approval automation (Make.com + Google Drive) ────
# When a grant is CAPPO-approved (approved_to_apply), Cappo POSTs the approval to
# this Make.com custom-webhook. The Make scenario creates the Drive folder + draft
# Google Docs, then calls back POST /api/grantops/automation/callback (authed with
# AGENT_API_KEY above) to link the folder onto the application. Blank = automation
# silently no-ops; the internal checklist + ClickUp deadline tasks still run.
MAKE_GRANTOPS_WEBHOOK_URL=
# Drive parent folder new grant-application folders are created under (the
# "Grant Applications" home). Copy the id from the folder's Drive URL. Blank =
# Make's scenario default (or My Drive root).
GRANTOPS_DRIVE_PARENT_FOLDER_ID=

# GitHub App identity for Cappo's ONE permitted write: appending a row to
# rmg-piaar-system's docs/INITIATIVES.md (agent.ts's add_initiative tool,
# src/lib/githubApp.ts). Reuses the SAME allen-piaar-control-bot App credentials
# already used by rmg-ai's ALLEN (already installed org-wide) -- copy the exact
# same values from allen-i-verse's Doppler project. Restriction to that one file
# is enforced at the tool layer here, not by GitHub permissions.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=

# ── ClickUp ──────────────────────────────────────────────────
# Personal API token: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=
# Optional: pin a workspace (team) id; auto-resolves to the first if blank
CLICKUP_TEAM_ID=
# Scope tasks/calendar to one Space (the AMG space). Blank = whole workspace.
CLICKUP_SPACE_ID=

# ── Notion ───────────────────────────────────────────────────
# Internal integration secret: https://www.notion.so/my-integrations
# Remember to share the relevant pages/databases with the integration.
NOTION_API_KEY=

# ── Google (Drive + Gmail + Login) ───────────────────────────
# One OAuth 2.0 client (Web application) from Google Cloud Console powers
# both app login and the Drive/Gmail connectors. Register BOTH redirect URIs:
#   - {APP_BASE_URL}/api/auth/callback/google        (login)
#   - {APP_BASE_URL}/api/connectors/google/callback  (connector authorization)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connectors/google/callback
